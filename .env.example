# Najaح environment variables — copy to .env.local and fill in real values
# NEVER commit .env.local

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# Server-side only (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# ----- Extra sign-in methods (configured in the Supabase dashboard, not here) -----
# Google sign-in: Supabase → Authentication → Providers → Google → enable +
#   paste Google OAuth client ID/secret, and add this redirect URL:
#   https://naja7dz.com/api/auth/callback   (and http://localhost:3000/api/auth/callback for dev)
# Phone (SMS OTP) sign-in: Supabase → Authentication → Providers → Phone →
#   enable and connect an SMS provider (e.g. Twilio).
# The buttons already exist in the UI; they start working once these are set.

# ===== AI =====
# Required for the AI tutor (/eleve/tuteur). Get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ===== Email (Resend) =====
# Required for welcome emails, contact form confirmations.
# Get from resend.com → API Keys. Domain must be verified in Resend.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Najaح <noreply@naja7dz.com>

# ===== Chargily Pay =====
CHARGILY_PUBLIC_KEY=test_pk_...
CHARGILY_SECRET_KEY=test_sk_...
CHARGILY_API_BASE=https://pay.chargily.net/test/api/v2
# Required in production — get from Chargily dashboard → Webhooks → secret
CHARGILY_WEBHOOK_SECRET=

# Public URL for redirect after payment
NEXT_PUBLIC_SITE_URL=https://naja7dz.com

# ===== Analytics & monitoring (optional) =====
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=naja7dz.com
# SENTRY_DSN=https://...@sentry.io/...
